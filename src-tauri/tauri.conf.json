{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Life Quest",
  "version": "1.0.2",
  "identifier": "com.jddevs.lifequest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Life Quest",
        "width": 1040,
        "height": 720,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "widget",
        "url": "index.html?widget=1",
        "title": "Pomo",
        "width": 128,
        "height": 54,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://pub-9e375d79fed34bf3a385cb4ce44390d8.r2.dev/updates/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwRDEzNDA5MkNGMDE4ODcKUldTSEdQQXNDVFRSTUZiUUJzVW5tcFpiWEMrTmg0WEw2MVZkRVVneGwzUWs3RnY2ZjZqdmlvSDcK"
    }
  }
}

{
  "name": "life-quest",
  "version": "1.0.2",
  "private": true,
  "description": "Life Quest — sistema de crecimiento personal gamificado (RPG-tamagotchi)",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-engine.mjs",
    "dev": "vite",
